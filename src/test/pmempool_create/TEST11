export UNITTEST_NAME=pmempool_create/TEST11
export UNITTEST_NUM=11

function ndctl_inject_error() {
	local NAMESPACE=$1
	local BLOCK=$2
	local COUNT=$3
	sudo ndctl inject-error --block=$BLOCK --count=$COUNT $NAMESPACE &>/dev/null
}

# standard unit test setup
. ../unittest/unittest.sh

require_test_type medium
require_fs_type any
require_kernel_module nfit_test_iomap
require_command ndctl
require_superuser
require_build_type debug nondebug

setup

ndctl disable-region all &> /dev/null
modprobe -r nfit_test
modprobe nfit_test
ndctl disable-region all &> /dev/null
ndctl zero-labels all &> /dev/null
ndctl enable-region all &> /dev/null

BUS="nfit_test.0"
REGION=$(ndctl list -b $BUS -t pmem -Ri | sed '/dev/!d;s/[", ]//g;s/dev://g' | tail -1)
DEVICE=$(ndctl create-namespace -b $BUS -r $REGION -f -m memory -a 4096 | sed '/blockdev/!d;s/[", ]//g;s/blockdev://g')
FULLDEV="/dev/$DEVICE"
NAMESPACE=$(ndctl list | grep -e "$DEVICE" -e namespace | grep -B1 -e "$DEVICE" | head -n1 | cut -d'"' -f4)

MOUNT_DIR=$DIR/mnt-pmem
FILE=$MOUNT_DIR/file

set +e
sudo umount $MOUNT_DIR 2>/dev/null
set -e
sudo mkfs.ext4 $FULLDEV &>/dev/null
sudo mkdir -p $MOUNT_DIR
sudo mount $FULLDEV $MOUNT_DIR
fallocate -l 10M $FILE
fallocate -l 10M $DIR/testfile1
fallocate -l 10M $DIR/testfile2

LOG=out${UNITTEST_NUM}.log
rm -rf $LOG && touch $LOG

POOLSET=$DIR/testset1
create_poolset $POOLSET 10M:$DIR/testfile1:x 10M:$FILE:x 10M:$DIR/testfile2:x

# expect_normal_exit $PMEMPOOL$EXESUFFIX rm $POOLSET

# inject bad block:
FIRST_SECTOR=$($EXTENTS $FILE | awk '{if (NR==1) print $1}')
SECTOR=$(($FIRST_SECTOR + 100))
ndctl_inject_error $NAMESPACE $SECTOR 1

expect_abnormal_exit $PMEMPOOL$EXESUFFIX create obj --layout pmempool$SUFFIX $POOLSET &> $LOG

sudo umount $MOUNT_DIR 2>/dev/null
ndctl disable-region all &> /dev/null
modprobe -r nfit_test

check

pass

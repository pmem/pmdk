util_file_open$(nW)TEST1w: START: util_file_open
 $(nW)util_file_open$(nW) 0x4000 $(nW)testlink1 $(nW)testlink2 $(nW)testfile1 $(nW)testfile2
$(nW)testlink1: util_file_open: $(*)
$(nW)testlink2: util_file_open: $(*)

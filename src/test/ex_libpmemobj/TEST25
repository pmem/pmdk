# standard unit test setup
. ../unittest/unittest.sh

require_test_type medium

require_build_type debug nondebug

setup

touch txt_file_without_permissions.txt
chmod 111 txt_file_without_permissions.txt

touch file_without_permissions
chmod 111 file_without_permissions

touch file_with_changing_permissions
chmod 777 file_with_changing_permissions

cp ../../examples/libpmemobj/colony/ints.txt int.txt
cp ../../examples/libpmemobj/colony/pmemoids.txt pmemoid.txt

EX_PATH=../../examples/libpmemobj/colony

# big usage
expect_normal_exit $EX_PATH/colony not_enough_args &> out$UNITTEST_NUM.log

# create-colony: usage
expect_normal_exit $EX_PATH/colony $DIR/testfile create-colony &>> out$UNITTEST_NUM.log
# create-colony: file without permissions
expect_abnormal_exit $EX_PATH/colony $DIR/file_without_permissions/file create-colony int 20 &>> out$UNITTEST_NUM.log
# create-colony: unknown type
expect_normal_exit $EX_PATH/colony $DIR/testfile create-colony colu unknown_type 12 &>> out$UNITTEST_NUM.log
# create-colony: requested size > MAX
expect_normal_exit $EX_PATH/colony $DIR/testfile create-colony colu int 163792271970 &>> out$UNITTEST_NUM.log

# insert-int: usage
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-int &>> out$UNITTEST_NUM.log
# insert-int: colony does not exist
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-int colx 90 &>> out$UNITTEST_NUM.log
# insert-int: file without permissions
expect_normal_exit $EX_PATH/colony $DIR/file_with_changing_permissions create-colony colu int 14 &>> out$UNITTEST_NUM.log
chmod 111 file_with_changing_permissions
expect_normal_exit $EX_PATH/colony $DIR/file_with_changing_permissions insert-int colu 3 &>> out$UNITTEST_NUM.log

# insert-pmemoid: usage
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-pmemoid &>> out$UNITTEST_NUM.log
# insert-pmemoid: colony does not exist
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-pmemoid colx 45797851 2235666 &>> out$UNITTEST_NUM.log
# insert-pmemoid: file without permissions
chmod 777 file_with_changing_permissions
expect_normal_exit $EX_PATH/colony $DIR/file_with_changing_permissions create-colony colu pmemoid 9 &>> out$UNITTEST_NUM.log
chmod 111 file_with_changing_permissions
expect_normal_exit $EX_PATH/colony $DIR/file_with_changing_permissions insert-pmemoid colu 378787878 89898989 &>> out$UNITTEST_NUM.log

# usage
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-int-from-file &>> out$UNITTEST_NUM.log
# colony does not exist
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-int-from-file colx int.txt &>> out$UNITTEST_NUM.log
# file txt without permissions
expect_normal_exit $EX_PATH/colony $DIR/testfile create-colony coln int 6 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-int-from-file coln txt_file_without_permissions.txt &>> out$UNITTEST_NUM.log

# usage
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-pmemoid-from-file &>> out$UNITTEST_NUM.log
# colony does not exist
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-pmemoid-from-file colx pmemoid.txt &>> out$UNITTEST_NUM.log
# file txt without permissions
expect_normal_exit $EX_PATH/colony $DIR/testfile create-colony coln pmemoid 6 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-pmemoid-from-file coln txt_file_without_permissions.txt &>> out$UNITTEST_NUM.log

# usage
expect_normal_exit $EX_PATH/colony $DIR/testfile remove-item &>> out$UNITTEST_NUM.log
# colony does not exist
expect_normal_exit $EX_PATH/colony $DIR/testfile remove-item colx 15 &>> out$UNITTEST_NUM.log

# usage
expect_normal_exit $EX_PATH/colony $DIR/testfile remove-range &>> out$UNITTEST_NUM.log
# colony does not exist
expect_normal_exit $EX_PATH/colony $DIR/testfile remove-range colx 11 33 &>> out$UNITTEST_NUM.log

# usage
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content &>> out$UNITTEST_NUM.log
# colony does not exist
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content colx &>> out$UNITTEST_NUM.log

# usage
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony &>> out$UNITTEST_NUM.log
# colony does not exist
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony colx &>> out$UNITTEST_NUM.log

# usage
expect_normal_exit $EX_PATH/colony $DIR/testfile delete-free-blocks &>> out$UNITTEST_NUM.log
# colony does not exist
expect_normal_exit $EX_PATH/colony $DIR/testfile delete-free-blocks colx &>> out$UNITTEST_NUM.log

# usage
expect_normal_exit $EX_PATH/colony $DIR/testfile delete-colony &>> out$UNITTEST_NUM.log
# colony does not exist
expect_normal_exit $EX_PATH/colony $DIR/testfile delete-colony colx &>> out$UNITTEST_NUM.log

# big usage
expect_normal_exit $EX_PATH/colony $DIR/testfile unknown_operation &>> out$UNITTEST_NUM.log

# standard use
# creation colony of ints (block capacity = 5)
expect_normal_exit $EX_PATH/colony $DIR/testfile create-colony coli int 5 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content coli &>> out$UNITTEST_NUM.log

# insertion 20 ints from file
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-int-from-file coli int.txt &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content coli &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony coli &>> out$UNITTEST_NUM.log

# removal one item (idx = 15)
expect_normal_exit $EX_PATH/colony $DIR/testfile remove-item coli 15 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content coli &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony coli &>> out$UNITTEST_NUM.log

# 2x removal range (idx = 15 does not exist, idx = 20 is out of range)
expect_normal_exit $EX_PATH/colony $DIR/testfile remove-range coli 14 20 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile remove-range coli 5 10 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content coli &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony coli &>> out$UNITTEST_NUM.log

# insert one int (idx = 10)
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-int coli 183 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content coli &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony coli &>> out$UNITTEST_NUM.log

# deletion free blocks (2)
expect_normal_exit $EX_PATH/colony $DIR/testfile delete-free-blocks coli &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content coli &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony coli &>> out$UNITTEST_NUM.log

# insertion 20 ints from file
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-int-from-file coli int.txt &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content coli &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony coli &>> out$UNITTEST_NUM.log

# deletion colony
expect_normal_exit $EX_PATH/colony $DIR/testfile delete-colony coli &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content coli &>> out$UNITTEST_NUM.log

# creation colony of PMEMoids (block capacity = 7)
expect_normal_exit $EX_PATH/colony $DIR/testfile create-colony colp pmemoid 7 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content colp &>> freopen$UNITTEST_NUM.log

# insertion 20 PMEMoids from file
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-pmemoid-from-file colp pmemoid.txt &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content colp &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony colp &>> out$UNITTEST_NUM.log

# removal range
expect_normal_exit $EX_PATH/colony $DIR/testfile remove-range colp 6 15 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content colp &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony colp &>> out$UNITTEST_NUM.log

# removal range
expect_normal_exit $EX_PATH/colony $DIR/testfile remove-range colp 0 5 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content colp &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony colp &>> out$UNITTEST_NUM.log

# deletion free blocks (2)
expect_normal_exit $EX_PATH/colony $DIR/testfile delete-free-blocks colp &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content colp &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony colp &>> out$UNITTEST_NUM.log

# insertion PMEMoids (20 from file and 4 single)
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-pmemoid-from-file colp pmemoid.txt &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-pmemoid colp 40731435551616 985633251211 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-pmemoid colp 35551698674407316 14073705021046740 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-pmemoid colp 98674447107335551 777441113705002 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-pmemoid colp 5858755551616 425370962235 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content colp &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony colp &>> out$UNITTEST_NUM.log

# removal range
expect_normal_exit $EX_PATH/colony $DIR/testfile remove-range colp 13 27 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content colp &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony colp &>> out$UNITTEST_NUM.log

# deletion free blocks
expect_normal_exit $EX_PATH/colony $DIR/testfile delete-free-blocks colp &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content colp &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony colp &>> out$UNITTEST_NUM.log

# removal range
expect_normal_exit $EX_PATH/colony $DIR/testfile remove-range colp 7 12 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content colp &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony colp &>> out$UNITTEST_NUM.log

# insertion PMEMoids (2 single)
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-pmemoid colp 120143452136336 891423258560 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile insert-pmemoid colp 41777698152307006 593257050241579 &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content colp &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-colony colp &>> out$UNITTEST_NUM.log

# deletion colony
expect_normal_exit $EX_PATH/colony $DIR/testfile delete-colony colp &>> out$UNITTEST_NUM.log
expect_normal_exit $EX_PATH/colony $DIR/testfile print-content colp &>> out$UNITTEST_NUM.log

rm -f int.txt
rm -f pmemoid.txt
rm -f file_with_changing_permissions
